# ─── StockSense AI — Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your real values.
# Never commit .env to version control.

# ─── LLM Provider Selection ───────────────────────────────────────────────────
# Choose your LLM provider: "openai" | "gemini" | "sarvam"
# This controls which API is used for report generation, competitor ID, etc.
LLM_PROVIDER=openai

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# Required if LLM_PROVIDER=openai (also used for embeddings regardless of provider)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# ─── Google Gemini ────────────────────────────────────────────────────────────
# Required if LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ─── Sarvam AI ────────────────────────────────────────────────────────────────
# Required if LLM_PROVIDER=sarvam
# Get your key at https://dashboard.sarvam.ai/
# Sarvam uses an OpenAI-compatible /chat/completions endpoint
SARVAM_API_KEY=your_sarvam_api_key_here
SARVAM_MODEL=sarvam-105b
SARVAM_BASE_URL=https://api.sarvam.ai/v1

# ─── News ─────────────────────────────────────────────────────────────────────
NEWSAPI_KEY=your_newsapi_key_here
SERP_API_KEY=your_serpapi_key_here

# ─── Social ───────────────────────────────────────────────────────────────────
# Twitter/X API v2 — only the Bearer Token is needed (app-only / read-only access)
# Get it from https://developer.twitter.com → Project → Keys & Tokens → Bearer Token
# You do NOT need Consumer Key/Secret or Access Token/Secret.
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# Reddit — no API key needed!
# Reddit posts are discovered via SerpAPI Google search (site:reddit.com) and scraped from old.reddit.com.
# Just make sure SERP_API_KEY (above) is set. If not, falls back to direct Reddit search scraping.

# ─── Database (Phase 2+) ──────────────────────────────────────────────────────
# Supabase project URL and keys (required for API/database features).
SUPABASE_URL=https://your-project-id.supabase.co
# Recommended for backend/server usage:
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
# Optional fallback for limited read access:
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─── ChromaDB (Phase 2+) ──────────────────────────────────────────────────────
CHROMA_DB_PATH=./chroma_db

# ─── Redis (Phase 5+) ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
