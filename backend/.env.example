# ─── StockSense AI — Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your real values.
# Never commit .env to version control.

# ─── LLM Provider Selection ───────────────────────────────────────────────────
LLM_PROVIDER=sarvam

# ─── Sarvam AI ────────────────────────────────────────────────────────────────
# Required if LLM_PROVIDER=sarvam
# Get your key at https://dashboard.sarvam.ai/
# Sarvam uses an OpenAI-compatible /chat/completions endpoint
SARVAM_API_KEY=your_sarvam_api_key_here
SARVAM_MODEL=sarvam-105b
SARVAM_BASE_URL=https://api.sarvam.ai/v1

# ─── News ─────────────────────────────────────────────────────────────────────
NEWSAPI_KEY=your_newsapi_key_here
SERP_API_KEY=your_serpapi_key_here

# ─── Database (Phase 2+) ──────────────────────────────────────────────────────
# Supabase project URL and keys (required for API/database features).
SUPABASE_URL=https://your-project-id.supabase.co
# Recommended for backend/server usage:
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
# Fallback for limited/public access:
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
